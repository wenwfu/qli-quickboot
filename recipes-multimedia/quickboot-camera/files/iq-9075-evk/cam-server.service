[Unit]
Description= Camera Server Service

# Manages the core camera server daemon.
# Triggered by udev rules (02-cam-server.rules) upon video device detection.
SourcePath=/usr/bin/cam-server

# Remove default dependenies (sysinit.target, basic.target) to enable early start
DefaultDependencies=no

# Start as soon as camera devices appear
After=dev-video0.device
Wants=dev-video0.device

[Service]
User=root
Group=root
SupplementaryGroups=
Restart=always
RuntimeDirectory=cam_server
RuntimeDirectoryMode=0775
CacheDirectory=camera
ExecCondition=/usr/bin/check-camx-overlay.sh
ExecStart=/usr/bin/cam-server

[Install]
WantedBy=multi-user.target
